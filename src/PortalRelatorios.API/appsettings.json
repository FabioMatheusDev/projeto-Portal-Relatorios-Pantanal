{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "AllowedHosts": "*",
  "Database": {
    "UseInMemoryDatabase": true,
    "HanaConnectionString": ""
  },
  "Jwt": {
    "Issuer": "PortalRelatorios",
    "Audience": "PortalRelatorios.Web",
    "SigningKey": "CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS!",
    "ExpireMinutes": 120
  },
  "Ldap": {
    "UseMock": true,
    "Server": "ldap://localhost",
    "Port": 389,
    "UseSsl": false,
    "BaseDn": "DC=company,DC=local",
    "BindUserDn": "",
    "BindPassword": "",
    "UserSearchFilter": "(&(objectClass=user)(objectCategory=person)(sAMAccountName={0}))",
    "ActiveUsersFilter": "(&(objectClass=user)(objectCategory=person)(!(userAccountControl:1.2.840.113556.1.4.803:=2)))"
  },
  "Sap": {
    "BaseUrl": "https://localhost:50000/",
    "CompanyDB": "",
    "UserName": "",
    "Password": "",
    "UseMockResponses": true
  },
  "ReportEndpoints": {
    "Routes": {
      "sample": "b1s/v1/$metadata"
    }
  },
  "Cors": {
    "Origins": [ "http://localhost:4200" ]
  }
}
